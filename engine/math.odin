package renderer

// Miscellaneous types used throughout the rendering code

int2 :: distinct [2]i32
int3 :: distinct [3]i32
int4 :: distinct [4]i32

uint2 :: distinct [2]u32
uint3 :: distinct [3]u32
uint4 :: distinct [4]u32

float2 :: distinct [2]f32
float3 :: distinct [3]f32
float4 :: distinct [4]f32
